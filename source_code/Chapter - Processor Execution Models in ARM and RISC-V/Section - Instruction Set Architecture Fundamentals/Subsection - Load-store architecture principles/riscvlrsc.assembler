RISC-V Atomic Increment Implementation


.section .text
.global atomic_inc64

atomic_inc64:
    lr.d    t0, (a0)            # load-reserved
    addi    t1, t0, 1           # increment
    sc.d    t2, t1, (a0)        # store-conditional, t2=0 on success
    bnez    t2, atomic_inc64    # retry if sc failed
    mv      a0, t1
    ret